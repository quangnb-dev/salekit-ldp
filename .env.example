# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://root:root@localhost:27017/salekit?authSource=admin
MONGO_ROOT_USER=root
MONGO_ROOT_PASS=root
MONGO_PORT=27017

# JWT — must be at least 16 characters each; replace with a strong random string in production
JWT_SECRET=change-me-min-16-chars
JWT_REFRESH_SECRET=change-me-too-min-16-chars

# mongo-express admin UI
ME_PORT=8081
ME_BASICAUTH_USER=admin
ME_BASICAUTH_PASS=pass
