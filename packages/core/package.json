{
  "name": "@salekit/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "immer": "^10",
    "interactjs": "^1.10.27",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "use-sync-external-store": "^1.6.0",
    "zod": "^4",
    "zundo": "^2",
    "zustand": "^5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5",
    "typescript": "~5.8",
    "vitest": "^4.1"
  }
}
